<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F9F9FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="90%"
                android:centerY="10%"
                android:startColor="#2676F3EA"
                android:endColor="#0076F3EA" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="10%"
                android:centerY="90%"
                android:startColor="#140A2647"
                android:endColor="#000A2647" />
        </shape>
    </item>
</layer-list>