<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.dipaapps"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.DipaApps">

        <!-- Splash Screen sebagai Gerbang Utama -->
        <activity
            android:name="com.example.dipaapps.SplashScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.example.dipaapps.AuthActivity" />
        <activity android:name="com.example.dipaapps.BaseActivity" />
        <activity android:name="com.example.dipaapps.MainActivity" />

        <!-- Activity Pertemuan (Pastikan jalur folder benar) -->
        <activity android:name="com.example.dipaapps.home.pertemuan_10.TenthActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan_9.NinthActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan_7.SeventhActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan_5.FifthActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan_5.WebViewActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan_4.FourthActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan3.ThirdActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan3.ThirdResultActivity" />
        <activity android:name="com.example.dipaapps.home.pertemuan2.SecondActivity" />

    </application>

</manifest>